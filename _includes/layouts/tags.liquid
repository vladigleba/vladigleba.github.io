---
layout: layouts/base
pagination:
  data: collections.allTags
  size: 1
  alias: tag
  addAllPagesToCollections: true
permalink: '/tag/{{ tag }}/'
eleventyComputed:
  title: '{{ tag | capitalize }}'
---

{% if site.enableTags %}
  {% assign tagData = collections.allPosts.tagsLookup[tag] %}
  {% assign countText = tagData.count | append: ' articles' %}
  {% render 'layouts/banner', title: title, description: countText %}

  <div class="category-view">
    <ol class="list standalone-list">
      {% for post in tagData.posts %}
          {% 
            render 'layouts/cards',
            post: post,
            site: site,
            mode: 'standalone-list'
          %}
        {% endfor %}
      </ol>
    </div>
{% endif %}
