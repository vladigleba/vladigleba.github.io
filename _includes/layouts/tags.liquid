---
layout: layouts/base
pagination:
  data: collections.allTags
  size: 1
  alias: tag
  addAllPagesToCollections: true
permalink: '/tag/{{ tag }}/'
eleventyComputed:
  title: '{{ tag | capitalize }}'
---

{% if site.enableTags %}
  {% assign tagData = collections.allPosts.tagsLookup[tag] %}
  {% assign countText = tagData.count | append: ' articles' %}
  {% render 'layouts/banner', title: title, description: countText %}

  <div class="control-wrapper">
    <div class="posts-sort">
      <label for="tag-selector" class="switch-label">Jump to:</label>
      <select id="tag-selector">
        {% for availableTag in collections.allTags %}
          <option value="/tag/{{ availableTag }}/" {% if availableTag == tag %}selected{% endif %}>
            {{ availableTag | capitalize }}
          </option>
        {% endfor %}
      </select>
      
      <svg class="select-arrow" aria-hidden="true">
        <use href="/assets/images/icons.svg#chevron-down"></use>
      </svg>
    </div>
  </div>

  <div class="category-view">
    <ol class="list standalone-list">
      {% for post in tagData.posts %}
          {% 
            render 'layouts/cards',
            post: post,
            site: site,
            mode: 'standalone-list'
          %}
        {% endfor %}
      </ol>
    </div>

    <script>
      const tagSelector = document.getElementById('tag-selector');
      tagSelector.addEventListener('change', (e) => {
        if (e.target.value) {
          window.location.href = e.target.value;
        }
      });
    </script>
{% endif %}
